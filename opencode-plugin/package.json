{
  "name": "opencode-devglobe",
  "version": "2.0.0",
  "description": "DevGlobe plugin for OpenCode - appear active on the globe while coding with AI",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --external:@opencode-ai/plugin"
  },
  "keywords": ["opencode", "devglobe", "heartbeat", "activity", "globe", "coding"],
  "author": { "name": "DevGlobe" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nako0/devglobe-extension",
    "directory": "opencode-plugin"
  },
  "homepage": "https://devglobe.app",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
