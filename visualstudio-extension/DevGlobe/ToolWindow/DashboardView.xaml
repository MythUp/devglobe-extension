<UserControl x:Class="DevGlobe.ToolWindow.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}">
    <StackPanel Margin="12">

        <TextBlock Text="DASHBOARD"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8" />

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Coding today" Opacity="0.7" FontSize="12" />
            <TextBlock Grid.Column="1" x:Name="CodingTimeText" Text="0m"
                       FontWeight="SemiBold" FontSize="12" />
        </Grid>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Language" Opacity="0.7" FontSize="12" />
            <TextBlock Grid.Column="1" x:Name="LanguageText" Text="--"
                       FontWeight="SemiBold" FontSize="12" />
        </Grid>

        <Separator Margin="0,12" />

        <TextBlock Text="STATUS MESSAGE"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" Opacity="0.8" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="StatusBox"
                     MaxLength="100" Padding="4,3"
                     KeyDown="StatusBox_KeyDown" />
            <Button Grid.Column="1" Content="Set" Margin="6,0,0,0" Padding="10,3"
                    Click="SetStatusButton_Click" />
        </Grid>
        <TextBlock Margin="0,6,0,0" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                   Text="Privacy &amp; visibility settings are managed on devglobe.app." />

        <Separator Margin="0,12" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="StopButton" Content="Stop Tracking"
                    Margin="0,0,3,0" Padding="8,3" FontSize="11"
                    Click="StopButton_Click" />
            <Button Grid.Column="1" x:Name="StartButton" Content="Start Tracking"
                    Margin="3,0,0,0" Padding="8,3" FontSize="11"
                    Click="StartButton_Click" />
        </Grid>

        <TextBlock HorizontalAlignment="Center" Margin="0,12,0,0">
            <Hyperlink x:Name="DisconnectLink" Click="DisconnectLink_Click">
                <Run Text="Disconnect" FontSize="11" />
            </Hyperlink>
        </TextBlock>

    </StackPanel>
</UserControl>
