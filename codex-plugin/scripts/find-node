#!/usr/bin/env bash
# Locate a Node.js binary. Prints the path to stdout, exits 1 if not found.

if [ -n "${NODE_BIN:-}" ] && [ -x "$NODE_BIN" ]; then
  echo "$NODE_BIN"
  exit 0
fi

if command -v node >/dev/null 2>&1; then
  command -v node
  exit 0
fi

for p in \
  /usr/local/bin/node \
  "$HOME/.nvm/current/bin/node" \
  "$HOME/.local/bin/node" \
  /run/current-system/sw/bin/node \
  /opt/homebrew/bin/node; do
  if [ -x "$p" ]; then
    echo "$p"
    exit 0
  fi
done

exit 1
