{
  "name": "devglobe-codex-plugin",
  "version": "2.0.0",
  "description": "DevGlobe skill for Codex CLI - appear active on the globe while coding with AI",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts src/setup.ts src/uninstall.ts src/update-status.ts --bundle --platform=node --target=node18 --outdir=dist",
    "watch": "esbuild src/index.ts src/setup.ts src/uninstall.ts src/update-status.ts --bundle --platform=node --target=node18 --outdir=dist --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
